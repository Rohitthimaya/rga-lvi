# AICanGrow Bot environment

# Express API server. Next.js proxies /api/* to this service in development.
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000

# Redis powers the BullMQ PDF ingestion worker.
REDIS_HOST=localhost
REDIS_PORT=6379

# Postgres with pgvector and tsvector indexes.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aicangrow

# S3-compatible storage for uploaded BC Ministry PDFs.
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
S3_BUCKET=aicangrow-rag-docs

# Model and parsing providers.
ANTHROPIC_API_KEY=replace-me
VOYAGE_API_KEY=replace-me
COHERE_API_KEY=replace-me
LLAMA_CLOUD_API_KEY=replace-me
GEMINI_API_KEY=replace-me
GEMINI_SUMMARY_MODEL=gemini-2.5-flash

# Optional local/free-tier ingestion controls.
# Set INGEST_MAX_PAGES for a quick partial index, then remove it for full indexing.
# Voyage free tier without billing is very rate limited, so use small batches + waits.
INGEST_MAX_PAGES=
SUMMARY_MODE=anthropic
SUMMARY_CONCURRENCY=1
SUMMARY_DELAY_MS=2000
SUMMARY_MAX_ATTEMPTS=8
SUMMARY_RETRY_MAX_DELAY_MS=65000
VOYAGE_EMBED_BATCH_SIZE=5
VOYAGE_EMBED_DELAY_MS=30000
VOYAGE_EMBED_MAX_ATTEMPTS=8

# Optional Langfuse observability.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
